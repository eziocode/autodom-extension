{
  "manifest_version": 3,
  "name": "AutoDOM",
  "key": "",
  "version": "3.0.4",
  "description": "Local MCP server for AI-driven browser automation. Connect your IDE agent to control the browser. Includes an inline AI chat panel powered by MCP.",
  "update_url": "https://eziocode.github.io/autodom-extension/updates.xml",
  "permissions": [
    "activeTab",
    "alarms",
    "scripting",
    "tabs",
    "storage",
    "debugger",
    "cookies",
    "clipboardWrite",
    "webNavigation",
    "sidePanel",
    "downloads",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "AutoDOM — open chat side panel"
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "toggle-chat-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Toggle AutoDOM AI Chat sidebar"
    },
    "toggle-inline-ai": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Toggle AutoDOM inline AI overlay"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "common/webext-api.js",
        "content/session-border.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*",
        "popup/*",
        "sidepanel/*",
        "content/chat-panel.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
